{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Reggae One|Shippori Mincho|Noto Serif|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Reggae One, Shippori Mincho, Noto Serif, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|as|disabled|block|iconLeft|iconRight|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, as, disabled, block, iconLeft, iconRight, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|tone|title|children|style|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: label, tone, title, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|sub|ink|green)$/]",
        "message": "<Callout> tone must be one of 'accent' | 'sub' | 'ink' | 'green'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SealSpec'] > JSXAttribute > JSXIdentifier[name!=/^(?:jp|en|tone|variant|key|ref|className|style|children)$/]",
        "message": "<SealSpec> doesn't accept that prop. Declared props: jp, en, tone, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='SealSpec'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|easy|mid|hard|ink|sub)$/]",
        "message": "<SealSpec> tone must be one of 'accent' | 'easy' | 'mid' | 'hard' | 'ink' | 'sub'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SealSpec'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|solid)$/]",
        "message": "<SealSpec> variant must be one of 'outline' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CodeLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|kind|prompt|key|ref|className|style|children)$/]",
        "message": "<CodeLine> doesn't accept that prop. Declared props: text, kind, prompt."
      },
      {
        "selector": "JSXOpeningElement[name.name='CodeLine'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:com|acc|green|)$/]",
        "message": "<CodeLine> kind must be one of 'com' | 'acc' | 'green' | ''."
      },
      {
        "selector": "JSXOpeningElement[name.name='Seal'] > JSXAttribute > JSXIdentifier[name!=/^(?:jp|en|variant|tone|size|rotate|style|key|ref|className|style|children)$/]",
        "message": "<Seal> doesn't accept that prop. Declared props: jp, en, variant, tone, size, rotate, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Seal'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:outline|solid)$/]",
        "message": "<Seal> variant must be one of 'outline' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Seal'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|easy|mid|hard|ink|sub)$/]",
        "message": "<Seal> tone must be one of 'accent' | 'easy' | 'mid' | 'hard' | 'ink' | 'sub'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Seal'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Seal> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|hash|active|as|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, hash, active, as, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
